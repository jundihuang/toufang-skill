{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-optimization-agent/optimization-output.schema.json",
  "title": "OptimizationOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["performanceSnapshot", "diagnostics", "optimizationActions", "reporting"],
  "properties": {
    "performanceSnapshot": {
      "type": "object",
      "additionalProperties": true
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": true
    },
    "optimizationActions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "findings", "nextActions", "learnings"],
      "properties": {
        "summary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "findings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nextActions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "learnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
